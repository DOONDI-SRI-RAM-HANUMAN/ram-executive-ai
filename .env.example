# Copy this file to .env and fill in your real key for local testing with `vercel dev`.
# NEVER commit a real .env file — only this .env.example template.

# Required: your secret key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Optional: which OpenAI model to use. Defaults to gpt-5.4-mini if unset.
OPENAI_MODEL=gpt-5.4-mini
